# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production

# Allowed Hosts - comma-separated values
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# CSRF Protection - comma-separated values with protocol
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.onrender.com

# Database Configuration
# Leave empty for SQLite (development)
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# Python Version (for Render deployment)
PYTHON_VERSION=3.13.3

# API Pagination
API_PAGE_SIZE=10

# Email Configuration (if needed)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
